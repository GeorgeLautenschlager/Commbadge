<?xml version="1.0" encoding="utf-8"?>
<!--
  TNG-style combadge: gold chevron/arrowhead on an oval backing plate.
  Original vector interpretation — no copyrighted assets used.
  ViewBox: 200 x 200
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- Outer oval backing plate — dark gunmetal -->
    <path
        android:pathData="M100,10
            C140,10 175,35 185,65
            C195,90 195,110 185,135
            C175,165 140,190 100,190
            C60,190 25,165 15,135
            C5,110 5,90 15,65
            C25,35 60,10 100,10 Z"
        android:fillColor="#3A3A4A"
        android:strokeColor="#888899"
        android:strokeWidth="2" />

    <!-- Inner oval highlight ring -->
    <path
        android:pathData="M100,18
            C137,18 169,41 179,68
            C188,92 188,108 179,132
            C169,159 137,182 100,182
            C63,182 31,159 21,132
            C12,108 12,92 21,68
            C31,41 63,18 100,18 Z"
        android:fillColor="#00000000"
        android:strokeColor="#555566"
        android:strokeWidth="1" />

    <!-- Gold chevron / arrowhead — main body -->
    <!-- Large left wing -->
    <path
        android:pathData="M100,45 L42,155 L75,155 L100,100 Z"
        android:fillColor="#C8A84B"
        android:strokeColor="#E8C860"
        android:strokeWidth="1" />

    <!-- Large right wing -->
    <path
        android:pathData="M100,45 L158,155 L125,155 L100,100 Z"
        android:fillColor="#B8943B"
        android:strokeColor="#D8B850"
        android:strokeWidth="1" />

    <!-- Small upper pip / divider between wings -->
    <path
        android:pathData="M100,45 L108,62 L100,57 L92,62 Z"
        android:fillColor="#E8C860"
        android:strokeColor="#F0D070"
        android:strokeWidth="0.5" />

    <!-- Center highlight line on chevron -->
    <path
        android:pathData="M100,50 L100,150"
        android:fillColor="#00000000"
        android:strokeColor="#D4AA5033"
        android:strokeWidth="1.5" />

    <!-- Metallic sheen overlay on left wing -->
    <path
        android:pathData="M100,45 L55,130 L42,155 L75,155 L100,100 Z"
        android:fillColor="#F0D06020"
        android:strokeColor="#00000000"
        android:strokeWidth="0" />

    <!-- Bottom horizontal bar accent — LCARS style -->
    <path
        android:pathData="M38,160 L162,160 L162,165 L38,165 Z"
        android:fillColor="#C8A84B"
        android:strokeColor="#00000000"
        android:strokeWidth="0" />

    <!-- Small round pip bottom-center -->
    <path
        android:pathData="M96,168 A4,4 0 1,0 104,168 A4,4 0 1,0 96,168 Z"
        android:fillColor="#E8C860"
        android:strokeColor="#F0D070"
        android:strokeWidth="0.5" />

</vector>
